{% comment %}
  ==================================================
  FULLY RESPONSIVE HEADER WITH SCROLL HIDE/SHOW
  ==================================================
{% endcomment %}

<div class="header-section-wrapper">
  <header class="site-header" id="siteHeader" role="banner">
    <div class="nav-container">
      
      <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Open Menu">
        <i class="fas fa-bars"></i>
      </button>

      <div class="logo-area">
        {% if section.settings.logo != blank %}
          <a href="{{ shop.url }}" class="logo-link logo-image">
            <img 
              src="{{ section.settings.logo | img_url: section.settings.logo_width }}" 
              alt="{{ shop.name }}"
              width="{{ section.settings.logo_width }}"
              height="auto"
              loading="eager"
              class="logo-img"
            >
          </a>
        {% else %}
          <a href="{{ shop.url }}" class="logo-link logo-text">
            {{ section.settings.logo_text | default: shop.name }}
          </a>
        {% endif %}
      </div>

      <nav class="nav-menu-wrapper" id="mainNavMenu">
        <div class="mobile-menu-header">
           <span class="mobile-menu-title">Menu</span>
           <button class="close-menu" id="closeMenu"><i class="fas fa-times"></i></button>
        </div>

        <div class="mobile-search-container">
           <form action="{{ routes.search_url }}" method="get" class="search-form">
            <input type="text" name="q" class="search-input" placeholder="Search products...">
            <button type="submit" class="search-submit"><i class="fas fa-search"></i></button>
          </form>
        </div>

        <ul class="main-nav-links">
          {% for link in linklists[section.settings.menu].links %}
            <li class="nav-item {% if link.links != blank %}has-dropdown{% endif %}">
              <a href="{{ link.url }}" class="nav-link">
                {{ link.title }}
                {% if link.links != blank %}
                  <i class="fas fa-chevron-down dropdown-icon"></i>
                {% endif %}
              </a>
              
              {% if link.links != blank %}
                <ul class="dropdown-menu">
                  {% for child_link in link.links %}
                    <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>

      <div class="search-wrapper desktop-only">
        <form action="{{ routes.search_url }}" method="get" class="search-form" role="search">
          <i class="fas fa-search search-icon"></i>
          <input 
            type="text" 
            name="q" 
            class="search-input" 
            placeholder="Search for products..." 
            value="{{ search.terms | escape }}"
          >
        </form>
      </div>

      <div class="user-actions">
        <a href="{{ routes.search_url }}" class="action-icon mobile-only" aria-label="Search">
           <i class="fas fa-search"></i>
        </a>
        {% if shop.customer_accounts_enabled %}
          <a href="{{ routes.account_url }}" class="action-icon" aria-label="Account">
            <i class="far fa-user"></i>
          </a>
        {% endif %}
        <a href="{{ routes.cart_url }}" class="action-icon" aria-label="Shopping cart">
          <i class="fas fa-shopping-bag"></i>
          <span class="cart-count">{{ cart.item_count }}</span>
        </a>
      </div>

    </div>
  </header>
</div>

<style>
  /* ========== CORE RESET & VARIABLES ========== */
  :root {
    --header-bg: {{ section.settings.header_background }};
    --nav-text: {{ section.settings.nav_text_color }};
    --nav-hover: {{ section.settings.nav_hover_color }};
    --accent: {{ section.settings.accent_color }};
    --header-h: {{ section.settings.header_height }}px;
  }

  .header-section-wrapper { height: var(--header-h); }

  .site-header {
    background-color: var(--header-bg);
    border-bottom: 1px solid #eaeef2;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    height: var(--header-h);
  }

  /* Scroll Logic Classes */
  .site-header.header-hidden { transform: translateY(-100%); }
  .site-header.header-visible { transform: translateY(0); box-shadow: 0 4px 10px rgba(0,0,0,0.05); }

  .nav-container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: 20px;
  }

  /* ========== LOGO ========== */
  .logo-text {
    font-size: clamp(20px, 5vw, {{ section.settings.logo_text_size }}px);
    font-weight: {{ section.settings.logo_text_weight }};
    text-decoration: none;
    color: #000;
    white-space: nowrap;
    display: block;
  }
  .logo-img { max-height: calc(var(--header-h) - 20px); width: auto; display: block; }

  /* ========== NAVIGATION (DESKTOP) ========== */
  .main-nav-links { display: flex; list-style: none; gap: 30px; margin: 0; padding: 0; }
  .nav-link {
    text-decoration: none;
    font-weight: 500;
    font-size: {{ section.settings.nav_font_size }}px;
    color: var(--nav-text);
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--nav-hover); }

  @media (min-width: 992px) {
    .dropdown-menu {
      position: absolute;
      top: 100%;
      left: 0;
      background: #fff;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      min-width: 220px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(10px);
      transition: 0.3s;
      padding: 15px 0;
      border-radius: 8px;
      list-style: none;
    }
    .nav-item:hover .dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
    .dropdown-menu a { display: block; padding: 8px 20px; color: #333; text-decoration: none; }
    .dropdown-menu a:hover { background: #f8f9fa; }
    .mobile-menu-header, .mobile-search-container, .mobile-only { display: none; }
    .mobile-menu-toggle { display: none; }
  }

  /* ========== SEARCH & ACTIONS ========== */
  .search-wrapper { flex: 1; max-width: 450px; position: relative; }
  .search-input {
    width: 100%;
    padding: 10px 15px 10px 45px;
    border-radius: 25px;
    border: 1px solid #e5e7eb;
    background: #f3f4f6;
    outline: none;
  }
  .search-icon { position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #9ca3af; }

  .user-actions { display: flex; gap: 20px; align-items: center; }
  .action-icon { font-size: 22px; color: {{ section.settings.icon_color }}; position: relative; text-decoration: none; transition: 0.2s; }
  .action-icon:hover { color: var(--accent); }
  .cart-count {
    position: absolute; top: -8px; right: -10px;
    background: var(--accent);
    color: #fff; font-size: 10px; padding: 2px 6px; border-radius: 20px;
  }

  /* ========== MOBILE STYLES ========== */
  @media (max-width: 991px) {
    .desktop-only { display: none; }
    .mobile-menu-toggle { display: flex; background: none; border: none; font-size: 24px; cursor: pointer; color: var(--nav-text); }
    
    body.menu-open { overflow: hidden; }

    .nav-menu-wrapper {
      position: fixed;
      top: 0; left: -100%;
      width: 100%; max-width: 320px; height: 100vh;
      background: #fff;
      padding: 20px;
      transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 10px 0 20px rgba(0,0,0,0.1);
      z-index: 2000;
      display: flex;
      flex-direction: column;
      overflow-y: auto;
    }

    .nav-menu-wrapper.active { left: 0; }
    .mobile-menu-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .mobile-menu-title { font-weight: 700; font-size: 20px; }
    .close-menu { background: none; border: none; font-size: 20px; cursor: pointer; }
    
    .mobile-search-container { margin-bottom: 25px; position: relative; }
    .mobile-search-container .search-input { padding: 12px 15px; width: 100%; background: #f9fafb; border: 1px solid #eee; }
    .search-submit { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #999; }

    .main-nav-links { flex-direction: column; gap: 0; }
    .nav-item { border-bottom: 1px solid #f3f4f6; }
    .nav-link { padding: 15px 0; justify-content: space-between; width: 100%; }
    
    .dropdown-menu { display: none; padding: 0 0 15px 15px; list-style: none; }
    .nav-item.open-mobile .dropdown-menu { display: block; }
    .nav-item.open-mobile .dropdown-icon { transform: rotate(180deg); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const header = document.getElementById('siteHeader');
    const toggle = document.getElementById('mobileMenuToggle');
    const closeBtn = document.getElementById('closeMenu');
    const menu = document.getElementById('mainNavMenu');
    const body = document.body;

    let lastScrollY = window.scrollY;

    // --- SCROLL HIDE/SHOW ---
    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;
      if (menu.classList.contains('active')) return;

      if (currentScrollY > lastScrollY && currentScrollY > 150) {
        header.classList.add('header-hidden');
      } else {
        header.classList.remove('header-hidden');
        if (currentScrollY > 50) {
          header.classList.add('header-visible');
        } else {
          header.classList.remove('header-visible');
        }
      }
      lastScrollY = currentScrollY;
    }, { passive: true });

    // --- MOBILE MENU TOGGLES ---
    const openMenu = () => {
      menu.classList.add('active');
      body.classList.add('menu-open');
    };

    const closeMenu = () => {
      menu.classList.remove('active');
      body.classList.remove('menu-open');
    };

    if (toggle) toggle.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);

    // Close on backdrop click
    document.addEventListener('click', (e) => {
      if (menu.classList.contains('active') && !menu.contains(e.target) && !toggle.contains(e.target)) {
        closeMenu();
      }
    });

    // Mobile Dropdowns (Accordion Style)
    const dropdownLinks = document.querySelectorAll('.has-dropdown > .nav-link');
    dropdownLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        if (window.innerWidth < 992) {
          e.preventDefault();
          const parent = link.parentElement;
          parent.classList.toggle('open-mobile');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo Settings"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (fallback)",
      "default": "SHOP.CO"
    },
    {
      "type": "range",
      "id": "logo_text_size",
      "label": "Logo text size",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "logo_text_weight",
      "label": "Logo text weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" }
      ],
      "default": "800"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container max width",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "range",
      "id": "header_height",
      "label": "Header height",
      "min": 60,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "header",
      "content": "Navigation Settings"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main navigation menu",
      "default": "main-menu"
    },
    {
      "type": "range",
      "id": "nav_font_size",
      "label": "Navigation font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "header_background",
      "label": "Header background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_text_color",
      "label": "Navigation text color",
      "default": "#1a1f2c"
    },
    {
      "type": "color",
      "id": "nav_hover_color",
      "label": "Navigation hover color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#1f2937"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Full Responsive Header"
    }
  ]
}
{% endschema %}