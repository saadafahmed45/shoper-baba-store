<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">

<div class="products_pages">
  <div class="container py-5">

    <!-- ================= BREADCRUMB ================= -->
    {% assign collection = product.collections.first %}

    <div class="row mb-4">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb align-items-center">

          <li class="breadcrumb-item">
            <a href="{{ routes.root_url }}">
              <i class="fa-solid fa-house me-1"></i> Home
            </a>
          </li>

          <li class="breadcrumb-item">
            <a href="/collections/all">
              <i class="fa-solid fa-shop me-1"></i> Shop
            </a>
          </li>

          {% if collection %}
          <li class="breadcrumb-item">
            <a href="{{ collection.url }}">
              {{ collection.title }}
            </a>
          </li>
          {% endif %}

          <li class="breadcrumb-item active">
            <i class="fa-solid fa-shirt me-1"></i> {{ product.title }}
          </li>

        </ol>
      </nav>
    </div>

    <!-- ================= PRODUCT ================= -->
    <div class="row">

      <!-- LEFT: Images -->
      <div class="col-md-6">
        <div class="product-gallery">

          <!-- Main Image -->
          <div class="main-image mb-3">
            <img id="mainProductImage"
              src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.featured_image.alt | default: product.title }}"
              class="img-fluid rounded">
          </div>

          <!-- Thumbnails -->
          <div class="d-flex gap-2 flex-wrap">
            {% for image in product.images limit: 5 %}
              <img src="{{ image | image_url: width: 100 }}"
                alt="{{ image.alt | default: product.title }}"
                class="img-thumbnail thumb-img"
                onclick="changeImage('{{ image | image_url: width: 600 }}')">
            {% endfor %}
          </div>

        </div>
      </div>

      <!-- RIGHT: Info -->
      <div class="col-md-6">

        <h2 class="fw-bold">{{ product.title }}</h2>

        <!-- Rating -->
        <div class="mb-2 text-warning">
          ★★★★☆ <span class="text-muted">(4.5/5)</span>
        </div>

        <!-- Price -->
        <div class="mb-3">
          <span class="fs-4 fw-bold text-dark">
            {{ product.price | money_without_trailing_zeros }}
          </span>

          {% if product.compare_at_price > product.price %}
            <span class="text-muted text-decoration-line-through ms-2">
              {{ product.compare_at_price | money_without_trailing_zeros }}
            </span>

            <span class="badge bg-danger ms-2">
              -{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%
            </span>
          {% endif %}
        </div>

        <!-- Description -->
        <p class="text-muted">
          {{ product.description | strip_html | truncate: 120 }}
        </p>

        <!-- ================= FORM ================= -->
        <form method="post" action="/cart/add">

          <!-- Variant -->
          {% if product.variants.size > 1 %}
            <div class="mb-3">
              <label class="fw-semibold">Choose Option</label>
              <select name="id" class="form-select mt-2">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}">
                    {{ variant.title }} - {{ variant.price | money }}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% else %}
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
          {% endif %}

          <!-- Quantity + Button -->
          <div class="d-flex align-items-center gap-3 mt-4">

            <div class="d-flex align-items-center bg-light rounded-pill p-2">
              <button type="button" class="qty-btn" onclick="decreaseQty()">-</button>
              <input type="number" name="quantity" id="qty" value="1" min="1"
                class="form-control text-center mx-2" style="width:70px;">
              <button type="button" class="qty-btn" onclick="increaseQty()">+</button>
            </div>

            {% if product.available %}
              <button type="submit" class="btn btn-dark w-100 py-2 rounded-pill">
                Add to Cart
              </button>
            {% else %}
              <button class="btn btn-secondary w-100 py-2 rounded-pill" disabled>
                Sold Out
              </button>
            {% endif %}

          </div>

        </form>

      </div>
    </div>

    <!-- ================= TABS ================= -->
    <div class="mt-5">
      <ul class="nav nav-tabs">
        <li class="nav-item">
          <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#details">
            Product Details
          </button>
        </li>
        <li class="nav-item">
          <button class="nav-link" data-bs-toggle="tab" data-bs-target="#reviews">
            Rating & Reviews
          </button>
        </li>
        <li class="nav-item">
          <button class="nav-link" data-bs-toggle="tab" data-bs-target="#faq">
            FAQs
          </button>
        </li>
      </ul>

      <div class="tab-content p-4 border border-top-0">

        <div class="tab-pane fade show active" id="details">
          {{ product.description }}
        </div>

        <div class="tab-pane fade" id="reviews">
          <p>No reviews yet.</p>
        </div>

        <div class="tab-pane fade" id="faq">
          <p>FAQ will be added here.</p>
        </div>

      </div>
    </div>

  </div>
</div>

<!-- ================= CSS ================= -->
<style>
.breadcrumb {
  background: transparent;
  font-size: 14px;
}

.breadcrumb a {
  text-decoration: none;
  color: #555;
}

.breadcrumb a:hover {
  color: black;
}

.breadcrumb-item.active {
  color: black;
  font-weight: 600;
}

.thumb-img {
  width: 70px;
  border-radius: 10px;
  cursor: pointer;
}

.main-image img {
  background: #f5f5f5;
  padding: 20px;
  border-radius: 20px;
}

.qty-btn {
  border: none;
  padding: 6px 12px;
  background: transparent;
  font-size: 18px;
  cursor: pointer;
}
</style>

<!-- ================= JS ================= -->
<script>
function changeImage(src) {
  document.getElementById("mainProductImage").src = src;
}

function increaseQty() {
  let qty = document.getElementById("qty");
  qty.value = parseInt(qty.value) + 1;
}

function decreaseQty() {
  let qty = document.getElementById("qty");
  if (qty.value > 1) {
    qty.value = parseInt(qty.value) - 1;
  }
}
</script>

{% schema %}
{
  "name": "Main Product Page",
  "tag": "section",
  "settings": []
}
{% endschema %}