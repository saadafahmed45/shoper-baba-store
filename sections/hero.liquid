<div class="hero_section">
  <div class="my_container">
    <div class="wrapper">

      <!-- Content -->
      <div class="hero_content">
        <div class="hero_badge">New Collection 2024</div>

        <h1>FIND CLOTHES THAT MATCHES YOUR STYLE</h1>

        <p>
          Browse through our diverse range of meticulously crafted garments,
          designed to bring out your individuality and cater to your sense of style.
        </p>

        <div class="hero_actions">
          <button class="btn-dark">Shop Now</button>
          <button class="btn-outline">Explore Looks</button>
        </div>

        <div class="counter_sec">
          <div class="counter">
            <h2>200+</h2>
            <span>International Brands</span>
          </div>

          <div class="divider"></div>

          <div class="counter">
            <h2>2,000+</h2>
            <span>Happy Customers</span>
          </div>

          <div class="divider"></div>

          <div class="counter">
            <h2>30+</h2>
            <span>Countries Served</span>
          </div>
        </div>
      </div>

      <!-- Image -->
      <div class="hero_img">

        {% if section.settings.hero_img %}
          <img 
            src="{{ section.settings.hero_img | image_url: width: 1200 }}" 
            alt="{{ section.settings.hero_img_alt | default: 'Hero image' }}"
            loading="eager"
          >
        {% else %}
          <div class="hero_placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <p>Upload hero image</p>
          </div>
        {% endif %}

        <!-- Floating Tags -->
        <div class="float_tag float_tag--top">
          <span class="dot"></span> New Arrivals
        </div>

        <div class="float_tag float_tag--bottom">
          ⭐ 4.9 Rating
        </div>

      </div>

    </div>
  </div>
</div>

<style>
:root {
  --hero-bg: {{ section.settings.hero_bg_color | default: '#FAF8F5' }};
  --text-dark: #0f0f0f;
  --text-mid: #555;
  --text-light: #888;
  --accent: #0f0f0f;
  --accent-hover: #2a2a2a;
  --border: #e5e0d8;
  --radius-pill: 50px;
  --radius-card: 20px;
  --font-display: 'Syne', sans-serif;
  --font-body: 'Manrope', sans-serif;
  --container: {{ section.settings.container_width | default: 1200 }}px;
}

.hero_section {
  background-color: var(--hero-bg);
  padding: 80px 0 60px;
  overflow: hidden;
  position: relative;
}

.hero_section::before {
  content: '';
  position: absolute;
  top: -120px;
  right: -120px;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(0,0,0,0.04) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.my_container {
  max-width: var(--container);
  margin: 0 auto;
  padding: 0 24px;
  box-sizing: border-box;
}

.wrapper {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 60px;
}

.hero_content {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.hero_badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dark);
  background: white;
  border: 1px solid var(--border);
  padding: 6px 16px;
  border-radius: var(--radius-pill);
  width: fit-content;
}

.hero_content h1 {
  font-family: var(--font-display);
  font-size: clamp(32px, 4.5vw, 58px);
  font-weight: 800;
  line-height: 1.1;
  color: var(--text-dark);
  margin: 0;
}

.hero_content p {
  font-family: var(--font-body);
  font-size: clamp(15px, 1.2vw, 18px);
  line-height: 1.7;
  color: var(--text-mid);
  margin: 0;
  max-width: 480px;
}

.hero_actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.btn-dark {
  background: var(--text-dark);
  color: #fff;
  padding: 14px 36px;
  border-radius: var(--radius-pill);
  border: none;
  cursor: pointer;
  transition: 0.3s;
}

.btn-dark:hover {
  background: var(--accent-hover);
  transform: translateY(-2px);
}

.btn-outline {
  background: transparent;
  border: 2px solid var(--border);
  padding: 14px 36px;
  border-radius: var(--radius-pill);
  cursor: pointer;
  transition: 0.3s;
}

.btn-outline:hover {
  border-color: var(--text-dark);
}

.counter_sec {
  display: flex;
  border-top: 1px solid var(--border);
  padding-top: 24px;
}

.counter {
  flex: 1;
}

.counter h2 {
  font-size: 28px;
  margin: 0;
}

.counter span {
  font-size: 13px;
  color: var(--text-light);
}

.divider {
  width: 1px;
  background: var(--border);
  margin: 0 20px;
}

.hero_img {
  position: relative;
}

.hero_img img {
  width: 100%;
  max-width: 520px;
  border-radius: var(--radius-card);
  box-shadow: 0 24px 60px rgba(0,0,0,0.12);
}

.hero_placeholder {
  width: 100%;
  max-width: 520px;
  aspect-ratio: 4/5;
  background: #ede9e3;
  border-radius: var(--radius-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.float_tag {
  position: absolute;
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: 10px 18px;
  font-size: 13px;
  animation: floatY 4s ease-in-out infinite;
}

.float_tag--top {
  top: 12%;
  left: -10px;
}

.float_tag--bottom {
  bottom: 12%;
  right: -10px;
}

@keyframes floatY {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

/* Responsive */
@media (max-width: 900px) {
  .wrapper {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .hero_content {
    align-items: center;
  }

  .counter_sec {
    justify-content: center;
  }
}
</style>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_img",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "hero_img_alt",
      "label": "Image Alt Text",
      "default": "Hero image"
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Background Color",
      "default": "#FAF8F5"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container Width (px)",
      "min": 1000,
      "max": 1600,
      "step": 20,
      "default": 1200
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}