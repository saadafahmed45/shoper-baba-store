<div class="hero_section">
  <div class="my_container">
    <div class="wrapper">

      <!-- Content -->
      <div class="hero_content">

        <h1>{{ section.settings.hero_heading }}</h1>

        <p>{{ section.settings.hero_paragraph }}</p>

        <div class="hero_actions">
          <a class="btn-dark" href="{{ section.settings.shop_button_url }}">
            {{ section.settings.shop_button }}
          </a>

          <a class="btn-outline" href="{{ section.settings.explore_button_url }}">
            {{ section.settings.explore_button }}
          </a>
        </div>

        <div class="counter_sec">
          <div class="counter">
            <h2>200+</h2>
            <span>International Brands</span>
          </div>

          <div class="divider"></div>

          <div class="counter">
            <h2>2,000+</h2>
            <span>Happy Customers</span>
          </div>

          <div class="divider"></div>

          <div class="counter">
            <h2>30+</h2>
            <span>Countries Served</span>
          </div>
        </div>
      </div>

      <!-- Image -->
      <div class="hero_img">

        {% if section.settings.hero_img %}
          <img 
            src="{{ section.settings.hero_img | image_url: width: 1200 }}"
            alt="{{ section.settings.hero_img_alt | default: 'Hero image' }}"
            loading="eager">
        {% else %}
          <div class="hero_placeholder">
            <p>Upload hero image</p>
          </div>
        {% endif %}

        <div class="float_tag float_tag--top">
          <span class="dot"></span>
          {{ section.settings.float_tag_top }}
        </div>

        <div class="float_tag float_tag--bottom">
          <span class="dot"></span>
          {{ section.settings.float_tag_bottom }}
        </div>

      </div>

    </div>
  </div>
</div>

<style>
  :root {
    --hero-bg: {{ section.settings.hero_bg_color | default: '#FAF8F5' }};
    --container: {{ section.settings.container_width | default: 1200 }}px;

    --text-dark: #0f0f0f;
    --text-mid: #555;
    --text-light: #888;
    --border: #e5e0d8;
    --radius-pill: 50px;
    --radius-card: 20px;
  }

  .hero_section {
    background-color: var(--hero-bg);
    padding: 80px 0 60px;
  }

  .my_container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 24px;
  }

  .wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero_content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .hero_content h1 {
    font-size: clamp(32px, 4.5vw, 58px);
    font-weight: 800;
  }

  .hero_content p {
    font-size: 16px;
    color: var(--text-mid);
    max-width: 480px;
  }

  .hero_actions {
    display: flex;
    gap: 16px;
  }

  .btn-dark,
  .btn-outline {
    padding: 14px 36px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    display: inline-block;
  }

  .btn-dark {
    background: #000;
    color: #fff;
  }

  .btn-outline {
    border: 2px solid var(--border);
    color: #000;
  }

  .counter_sec {
    display: flex;
    border-top: 1px solid var(--border);
    padding-top: 24px;
  }

  .divider {
    width: 1px;
    background: var(--border);
    margin: 0 20px;
  }

  .hero_img img {
    width: 100%;
    max-width: 520px;
    border-radius: var(--radius-card);
  }

  @media (max-width: 900px) {
    .wrapper {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }
</style>

{% schema %}
{
"name": "Hero Section",
"settings": [
{
"type": "text",
"id": "hero_heading",
"label": "Heading",
"default": "FIND CLOTHES THAT MATCHES YOUR STYLE"
},

{
"type": "textarea",
"id": "hero_paragraph",
"label": "Paragraph",
"default": "Browse through our diverse range of meticulously crafted garments, designed to bring out your individualityand cater to your sense of style."

},
{
  "type": "text",
  "id": "shop_button",
  "label": "Shop Now Button Text",
  "default": "Shop Now"
},
{
  "type": "text",
  "id": "explore_button",
  "label": "Explore Button Text",
  "default": "Explore Now"
},
{
"type": "url",
"id": "shop_button_url",
"label": "Shop Now Button URL",
"default": "/"

},
{
"type": "url",
"id": "explore_button_url",
"label": "Explore Button URL",
"default": "/"

},
{
"type": "text",
"id": "float_tag_top",
"label": "Top Floating Tag",
"default": "New Arrivals"

},
{
"type": "text",
"id": "float_tag_bottom",
"label": "Bottom Floating Tag",
"default": "⭐ 4.9 Rating"
},

{
"type": "image_picker",
"id": "hero_img",
"label": "Hero Image"
},
{
"type": "text",
"id": "hero_img_alt",
"label": "Image Alt Text",
"default": "Hero image"
},
{
"type": "color",
"id": "hero_bg_color",
"label": "Background Color",
"default": "#FAF8F5"
},
{
"type": "range",
"id": "container_width",
"label": "Container Width (px)",
"min": 1000,
"max": 1600,
"step": 20,
"default": 1200
}
],
"presets": [
{
"name": "Hero Section"
}
]
}
{% endschema %}