      "label": "Mobile description size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_counter_size",
      "label": "Mobile counter size",
      "min": 24,
      "max": 36,
