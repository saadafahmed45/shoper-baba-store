<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">

<footer class="footer-section py-5">
  <div class="container">
    <div class="row g-4">

      <!-- About -->
      <div class="col-lg-4 col-md-6">
        <h4 class="mb-4">{{ section.settings.about_title }}</h4>
        <p class="mb-4">{{ section.settings.about_text }}</p>

        <div class="social-links">
          {% if section.settings.facebook != blank %}
            <a href="{{ section.settings.facebook }}" class="social-icon bg-primary">
              <i class="fab fa-facebook-f"></i>
            </a>
          {% endif %}

          {% if section.settings.twitter != blank %}
            <a href="{{ section.settings.twitter }}" class="social-icon bg-info">
              <i class="fab fa-twitter"></i>
            </a>
          {% endif %}

          {% if section.settings.instagram != blank %}
            <a href="{{ section.settings.instagram }}" class="social-icon bg-danger">
              <i class="fab fa-instagram"></i>
            </a>
          {% endif %}

          {% if section.settings.linkedin != blank %}
            <a href="{{ section.settings.linkedin }}" class="social-icon bg-primary">
              <i class="fab fa-linkedin-in"></i>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Dynamic Menu 1 -->
      <div class="col-lg-2 col-md-6">
        <h5 class="mb-4">{{ section.settings.menu1_title }}</h5>
        <ul class="list-unstyled">
          {% for link in linklists[section.settings.menu1].links %}
            <li class="mb-2">
              <a href="{{ link.url }}" class="footer-link">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <!-- Dynamic Menu 2 -->
      <div class="col-lg-2 col-md-6">
        <h5 class="mb-4">{{ section.settings.menu2_title }}</h5>
        <ul class="list-unstyled">
          {% for link in linklists[section.settings.menu2].links %}
            <li class="mb-2">
              <a href="{{ link.url }}" class="footer-link">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-lg-4 col-md-6">
        <h5 class="mb-4">{{ section.settings.contact_title }}</h5>
        <ul class="list-unstyled">

          {% if section.settings.address != blank %}
          <li class="mb-3">
            <i class="fas fa-map-marker-alt me-2"></i>
            {{ section.settings.address }}
          </li>
          {% endif %}

          {% if section.settings.phone != blank %}
          <li class="mb-3">
            <i class="fas fa-phone me-2"></i>
            <a href="tel:{{ section.settings.phone }}" class="footer-link">
              {{ section.settings.phone }}
            </a>
          </li>
          {% endif %}

          {% if section.settings.email != blank %}
          <li class="mb-3">
            <i class="fas fa-envelope me-2"></i>
            <a href="mailto:{{ section.settings.email }}" class="footer-link">
              {{ section.settings.email }}
            </a>
          </li>
          {% endif %}

        </ul>
      </div>

    </div>

    <!-- Bottom -->
    <div class="row mt-5">
      <div class="col-12 text-center">
        <hr>
        <p class="mb-0">
          &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.
        </p>
      </div>
    </div>

  </div>
</footer>

<style>

 .footer-section {
  background: #f8f9fa;
  color: #333;
}

.footer-section h4,
.footer-section h5 {
  font-weight: 700;
}

.footer-link {
  color: #555;
  text-decoration: none;
  transition: 0.3s;
}

.footer-link:hover {
  color: #000;
  padding-left: 5px;
}

.social-links {
  display: flex;
  gap: 10px;
}

.social-icon {
  width: 38px;
  height: 38px;
  line-height: 38px;
  border-radius: 50%;
  text-align: center;
  color: #fff;
  display: inline-block;
  transition: 0.3s;
}

.social-icon:hover {
  transform: translateY(-4px);
}

/* Responsive Fix */
@media (max-width: 768px) {
  .footer-section {
    text-align: center;
  }

  .social-links {
    justify-content: center;
  }
}
</style>
{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "text",
      "id": "about_title",
      "label": "About Title",
      "default": "About Us"
    },
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About Text",
      "default": "Write about your company here..."
    },

    {
      "type": "text",
      "id": "menu1_title",
      "label": "Menu 1 Title",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "menu1",
      "label": "Menu 1"
    },

    {
      "type": "text",
      "id": "menu2_title",
      "label": "Menu 2 Title",
      "default": "Services"
    },
    {
      "type": "link_list",
      "id": "menu2",
      "label": "Menu 2"
    },

    {
      "type": "text",
      "id": "contact_title",
      "label": "Contact Title",
      "default": "Contact Info"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "Downtown,Toronto CA"

    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+12340576535"

    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": " example@gmail.com"

      
    },

    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL",
      "default": " https://www.linkedin.com/"

    },
    {
      "type": "url",
      "id": "twitter",
      "label": "Twitter URL",
      "default": " https://www.linkedin.com/"

    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL",
      "default": " https://www.linkedin.com/"

    },
    {
      "type": "url",
      "id": "linkedin",
      "label": "LinkedIn URL",
      "default": " https://www.linkedin.com/"
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}