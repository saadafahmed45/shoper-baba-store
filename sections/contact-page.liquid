<div class="contact_page_template">
  <div class="container">

    <h2 class="title">{{ page.title }}</h2>

    {% form 'contact' %}
      
      {% if form.posted_successfully? %}
        <p class="success">✅ Message sent successfully!</p>
      {% endif %}

      {% if form.errors %}
        <div class="error">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="form_group">
        <input 
          type="text" 
          name="contact[name]" 
          placeholder="Your Name" 
          required>
      </div>

      <div class="form_group">
        <input 
          type="email" 
          name="contact[email]" 
          placeholder="Your Email" 
          required>
      </div>

      <div class="form_group">
        <textarea 
          name="contact[body]" 
          placeholder="Your Message" 
          rows="5"
          required></textarea>
      </div>

      <button type="submit" class="btn_submit">
        Send Message
      </button>

    {% endform %}

  </div>
</div>

<style>
.contact_page_template {
  padding: 80px 0;
}

.container {
  max-width: 700px;
  margin: auto;
  padding: 0 20px;
}

.title {
  text-align: center;
  margin-bottom: 30px;
}

/* Form */
.form_group {
  margin-bottom: 20px;
}

.form_group input,
.form_group textarea {
  width: 100%;
  padding: 14px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 15px;
}

/* Button */
.btn_submit {
  width: 100%;
  padding: 14px;
  background: #000;
  color: #fff;
  border: none;
  border-radius: 30px;
  cursor: pointer;
  transition: 0.3s;
}

.btn_submit:hover {
  opacity: 0.8;
}

/* Messages */
.success {
  background: #e6ffed;
  padding: 12px;
  border-radius: 6px;
  margin-bottom: 20px;
  color: green;
}

.error {
  background: #ffe6e6;
  padding: 12px;
  border-radius: 6px;
  margin-bottom: 20px;
  color: red;
}

/* Responsive */
@media(max-width:768px){
  .contact_page_template {
    padding: 50px 0;
  }
}
</style>
