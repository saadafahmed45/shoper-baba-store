{% comment %}
  Modern Search Page Design (Products Focused)
{% endcomment %}

<div class="search-page container py-5">

  <!-- TITLE -->
  <div class="text-center mb-4">
    <h2 class="search-title">Search Results</h2>
    <p class="search-subtitle">
      Showing results for "<strong>{{ search.terms }}</strong>"
    </p>
  </div>

  <!-- SEARCH FORM -->
  <form action="{{ routes.search_url }}" method="get" class="search-bar mb-5">
    <input type="hidden" name="type" value="product">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="Search products..."
    >
    <button type="submit">Search</button>
  </form>

  {% if search.performed %}

    {% if search.results_count == 0 %}
      <div class="no-result text-center">
        <h4>No products found 😢</h4>
        <p>Try searching something else</p>
      </div>
    {% else %}

      <!-- PRODUCT GRID -->
      <div class="row g-4">

        {% paginate search.results by 12 %}
          {% for result in search.results %}
            
            {% if result.object_type == 'product' %}
              <div class="col-md-3 col-6">

                <div class="product-card">

                  <a href="{{ result.url }}">
                    <div class="product-image">
                      {% if result.featured_image %}
                        <img src="{{ result.featured_image | image_url: width: 400 }}">
                      {% else %}
                        <img src="https://via.placeholder.com/400x400">
                      {% endif %}
                    </div>
                  </a>

                  <div class="product-info text-center">
                    <h6>{{ result.title }}</h6>

                    {% if result.price %}
                      <p class="price">
                        {{ result.price | money }}
                      </p>
                    {% endif %}

                    <a href="{{ result.url }}" class="view-btn">
                      View Product
                    </a>
                  </div>

                </div>

              </div>
            {% endif %}

          {% endfor %}

          <!-- PAGINATION -->
          <div class="col-12 text-center mt-4">
            {{ paginate | default_pagination }}
          </div>

        {% endpaginate %}

      </div>

    {% endif %}

  {% endif %}

</div>

<style>
/* PAGE */
.search-title {
  font-size: 32px;
  font-weight: 700;
}
.search-subtitle {
  color: #777;
}

/* SEARCH BAR */
.search-bar {
  max-width: 500px;
  margin: auto;
  display: flex;
  border: 1px solid #ddd;
  border-radius: 30px;
  overflow: hidden;
}
.search-bar input {
  flex: 1;
  border: none;
  padding: 12px 15px;
  outline: none;
}
.search-bar button {
  background: #000;
  color: #fff;
  border: none;
  padding: 0 20px;
  cursor: pointer;
}

/* CARD */
.product-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  transition: 0.3s;
  border: 1px solid #eee;
}
.product-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

/* IMAGE */
.product-image img {
  width: 100%;
  height: 220px;
  object-fit: cover;
}

/* INFO */
.product-info {
  padding: 15px;
}
.product-info h6 {
  font-size: 14px;
  height: 40px;
  overflow: hidden;
}
.price {
  font-weight: 600;
  margin: 5px 0;
}

/* BUTTON */
.view-btn {
  display: inline-block;
  margin-top: 8px;
  padding: 6px 12px;
  background: #000;
  color: #fff;
  font-size: 12px;
  border-radius: 6px;
  text-decoration: none;
}

/* NO RESULT */
.no-result {
  padding: 50px 0;
}

/* RESPONSIVE */
@media(max-width:768px){
  .product-image img {
    height: 160px;
  }
}
</style>
{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
