<div class="cart_page py-5">
  <div class="container">

    <h2 class="fw-bold mb-4">🛒 Your Cart</h2>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post">

        <div class="row g-4">

          <!-- LEFT: CART ITEMS -->
          <div class="col-lg-8">

            {% for item in cart.items %}
              <div class="card mb-3 cart-card shadow-sm border-0">
                <div class="row g-0 align-items-center p-3">

                  <!-- Image -->
                  <div class="col-md-3 text-center">
                    <img src="{{ item.image | img_url: '300x' }}" class="img-fluid rounded">
                  </div>

                  <!-- Info -->
                  <div class="col-md-5 ml-3 mx-3">
                    <h5 class="fw-semibold">{{ item.product.title }}</h5>
                    <p class="text-muted mb-1">{{ item.variant.title }}</p>
                    <p class="fw-bold">{{ item.final_price | money }}</p>

                    <a href="{{ item.url_to_remove }}" class="text-danger small">
                      Remove
                    </a>
                  </div>

                  <!-- Quantity -->
                  <div class="col-md-2 text-center">
                    <div class="qty-box d-flex justify-content-center align-items-center">
                      <button type="button" onclick="decreaseQty({{ forloop.index0 }})">-</button>

                      <input 
                        type="number" 
                        name="updates[]" 
                        id="qty-{{ forloop.index0 }}"
                        value="{{ item.quantity }}" 
                        min="1"
                      >

                      <button type="button" onclick="increaseQty({{ forloop.index0 }})">+</button>
                    </div>
                  </div>

                  <!-- Total -->
                  <div class="col-md-2 text-end">
                    <p class="fw-bold">{{ item.final_line_price | money }}</p>
                  </div>

                </div>
              </div>
            {% endfor %}

          </div>

          <!-- RIGHT: SUMMARY -->
          <div class="col-lg-4">
            <div class="card shadow-sm p-4 border-0 summary-box">

              <h5 class="fw-bold mb-3">Order Summary</h5>

              <div class="d-flex justify-content-between mb-2">
                <span>Subtotal</span>
                <span>{{ cart.total_price | money }}</span>
              </div>

              <hr>

              <button type="submit" name="update" class="btn btn-outline-dark w-100 mb-2">
                Update Cart
              </button>

              <button type="submit" name="checkout" class="btn btn-dark w-100">
                Checkout
              </button>

            </div>
          </div>

        </div>

      </form>

    {% else %}
      <div class="text-center py-5">
        <h4>Your cart is empty 😢</h4>
        <a href="/" class="btn btn-dark mt-3">Continue Shopping</a>
      </div>
    {% endif %}

  </div>
</div>

<style>
.cart-card {
  border-radius: 15px;
  transition: 0.3s;
}

.cart-card:hover {
  transform: translateY(-3px);
}

.summary-box {
  border-radius: 15px;
}

/* Quantity box */
.qty-box {
  background: #f5f5f5;
  border-radius: 30px;
  padding: 5px 10px;
}

.qty-box button {
  border: none;
  background: none;
  font-size: 18px;
  width: 30px;
}

.qty-box input {
  width: 40px;
  border: none;
  text-align: center;
  background: transparent;
}

/* Mobile */
@media (max-width: 768px) {
  .cart-card .row {
    text-align: center;
  }

  .col-md-2,
  .col-md-5 {
    margin-top: 10px;
  }
}
</style>
<script>
function increaseQty(index) {
  let input = document.getElementById("qty-" + index);
  input.value = parseInt(input.value) + 1;
}

function decreaseQty(index) {
  let input = document.getElementById("qty-" + index);
  if (input.value > 1) input.value--;
}
</script>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
