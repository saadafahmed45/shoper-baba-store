<div class="cart_page py-5">
  <div class="container">

    <!-- Title -->
    <h2 class="cart-title mb-4">YOUR CART</h2>

    {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post">

      <div class="row g-4">

        <!-- LEFT -->
        <div class="col-lg-8">

          {% for item in cart.items %}
          <div class="cart-item">

            <div class="cart-left">
              <img src="{{ item.image | img_url: '300x' }}" alt="{{ item.product.title }}">
            </div>

            <div class="cart-middle">
              <h6>{{ item.product.title }}</h6>
              <p class="meta">{{ item.variant.title }}</p>
              <p class="price">{{ item.final_price | money }}</p>
            </div>

            <div class="cart-right">

              <!-- Qty -->
              <div class="qty-box">
                <button type="button" onclick="decreaseQty({{ forloop.index0 }})">-</button>

                <input 
                  type="number" 
                  name="updates[]" 
                  id="qty-{{ forloop.index0 }}"
                  value="{{ item.quantity }}" 
                  min="1"
                >

                <button type="button" onclick="increaseQty({{ forloop.index0 }})">+</button>
              </div>

              <!-- Remove -->
              <a href="{{ item.url_to_remove }}" class="remove-btn">🗑</a>

            </div>

          </div>
          {% endfor %}

        </div>

        <!-- RIGHT SUMMARY -->
        <div class="col-lg-4">
          <div class="summary-box">

            <h5>Order Summary</h5>

            <div class="summary-row">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <div class="summary-row discount">
              <span>Discount (-20%)</span>
              <span>-{{ cart.total_price | times: 0.2 | money }}</span>
            </div>

            <div class="summary-row">
              <span>Delivery Fee</span>
              <span>$15</span>
            </div>

            <hr>

            <div class="summary-total">
              <span>Total</span>
              <span>
                {{ cart.total_price | minus: cart.total_price | times: 0.2 | plus: 1500 | money }}
              </span>
            </div>

            <!-- Promo -->
            <div class="promo-box">
              <input type="text" placeholder="Add promo code">
              <button>Apply</button>
            </div>

            <!-- Checkout -->
            <button type="submit" name="checkout" class="checkout-btn">
              Go to Checkout →
            </button>

          </div>
        </div>

      </div>

    </form>

    {% else %}
      <div class="text-center py-5">
        <h4>Your cart is empty</h4>
      </div>
    {% endif %}

  </div>
</div>

<style>
.cart-title {
  font-weight: 800;
  font-size: 28px;
}

/* Cart Item */
.cart-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f6f6f6;
  padding: 20px;
  border-radius: 15px;
  margin-bottom: 15px;
}

.cart-left img {
  width: 80px;
  border-radius: 10px;
}

.cart-middle {
  flex: 1;
  margin-left: 15px;
}

.cart-middle h6 {
  font-weight: 600;
}

.meta {
  font-size: 13px;
  color: #777;
}

.price {
  font-weight: bold;
}

/* Right */
.cart-right {
  display: flex;
  align-items: center;
  gap: 15px;
}

/* Qty */
.qty-box {
  display: flex;
  align-items: center;
  background: #eee;
  border-radius: 30px;
  padding: 5px 10px;
}

.qty-box button {
  border: none;
  background: none;
  font-size: 18px;
  width: 30px;
}

.qty-box input {
  width: 40px;
  text-align: center;
  border: none;
  background: transparent;
}

/* Remove */
.remove-btn {
  color: red;
  font-size: 18px;
  text-decoration: none;
}

/* Summary */
.summary-box {
  background: #f6f6f6;
  padding: 25px;
  border-radius: 15px;
}

.summary-box h5 {
  margin-bottom: 20px;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
}

.discount span:last-child {
  color: red;
}

.summary-total {
  display: flex;
  justify-content: space-between;
  font-weight: bold;
  margin: 15px 0;
}

/* Promo */
.promo-box {
  display: flex;
  gap: 10px;
  margin-bottom: 15px;
}

.promo-box input {
  flex: 1;
  padding: 8px;
  border-radius: 20px;
  border: none;
}

.promo-box button {
  background: black;
  color: white;
  border: none;
  padding: 8px 15px;
  border-radius: 20px;
}

/* Checkout */
.checkout-btn {
  width: 100%;
  background: black;
  color: white;
  border: none;
  padding: 12px;
  border-radius: 30px;
  font-weight: 600;
}

</style>
<script>
function increaseQty(index) {
  let input = document.getElementById("qty-" + index);
  input.value = parseInt(input.value) + 1;
}

function decreaseQty(index) {
  let input = document.getElementById("qty-" + index);
  if (input.value > 1) input.value--;
}
</script>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
