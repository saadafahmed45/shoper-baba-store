<div class="collection-list-section py-5">
  <div class="container">

    <!-- Title -->
    <div class="text-center mb-5">
      <h2 class="collection-heading">{{ 'collections.title' | t }}</h2>
      <p class="collection-subtitle">Explore our curated categories</p>
    </div>

    <!-- Grid -->
    <div class="row g-4">

      {% for collection in collections %}
        <div class="col-lg-4 col-md-6">

          <a href="{{ collection.url }}" class="collection-card">

            <div class="collection-image">
              {% if collection.featured_image %}
                <img 
                  src="{{ collection.featured_image | image_url }}" 
                  alt="{{ collection.title }}"
                >
              {% endif %}

              <!-- Gradient Overlay -->
              <div class="overlay"></div>

              <!-- Content Center -->
              <div class="collection-content text-center">
                <h4>{{ collection.title }}</h4>
                <span>{{ collection.products_count }} Products</span>
              </div>

            </div>

          </a>

        </div>
      {% endfor %}

    </div>

  </div>
</div>

{% stylesheet %}
 .collection-list-section {
  background: #f8f8f8;
}

.collection-heading {
  font-size: 34px;
  font-weight: 700;
}

.collection-subtitle {
  color: #777;
  font-size: 14px;
}

/* Card */
.collection-card {
  display: block;
  border-radius: 18px;
  overflow: hidden;
  position: relative;
  text-decoration: none;
}

/* Image */
.collection-image {
  position: relative;
}

.collection-image img {
  width: 100%;
  height: 320px;
  object-fit: cover;
  transition: transform 0.6s ease;
}

/* Gradient Overlay */
.overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.6), rgba(0,0,0,0.1));
  opacity: 0;
  transition: 0.4s;
}

/* Content Center */
.collection-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, 20%);
  color: #fff;
  opacity: 0;
  transition: 0.4s;
}

.collection-content h4 {
  margin: 0;
  font-size: 24px;
  font-weight: 600;
}

.collection-content span {
  font-size: 14px;
}

/* Hover Effects */
.collection-card:hover img {
  transform: scale(1.1);
}

.collection-card:hover .overlay {
  opacity: 1;
}

.collection-card:hover .collection-content {
  transform: translate(-50%, -50%);
  opacity: 1;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collections_grid",
  "settings": [
    {
      "type": "select",
      "id": "grid_item_width",
      "label": "t:labels.grid_item_width",
      "options": [
        { "value": "collections--compact", "label": "t:options.size.small" },
        { "value": "collections--full", "label": "t:options.size.large" }
      ],
      "default": "collections--full"
    }
    
  ],
  "presets": [{ "name": "t:general.collections_grid" }]
}
{% endschema %}
