{% comment %}
  This section is used in the page template to render store pages like About us
  or Contact us.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/page
{% endcomment %}

<div class="container py-5">
  {% if page.title != blank %}
    <h1>{{ page.title }}</h1>
  {% endif %}

  <div class="page_content">
    {{ page.content }}
  </div>
</div>
{% schema %}
{
  "name": "t:general.page",
  "settings": []
}
{% endschema %}
