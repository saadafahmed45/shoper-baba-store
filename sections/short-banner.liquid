<div class="short_banner 
  height-{{ section.settings.banner_height }} 
  align-{{ section.settings.text_align }} 
  {% if section.settings.parallax %}parallax{% endif %}"
  style="background-image: url({{ section.settings.bg_image | image_url: width: 2000 }});">

  {% comment %} 
    The overlay opacity is now controlled dynamically.
    We convert the 0-100 range from schema into 0.0-1.0 using the liquid divided_by filter.
  {% endcomment %}
  <div class="overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>

  <div class="container">
    <div class="banner_content">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtext }}</p>

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_url }}" class="btn">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

<style>
.short_banner {
  position: relative;
  background-size: cover;
  background-position: center;
  display: flex;
  align-items: center;
}

/* Heights */
.height-small { height: 200px; }
.height-medium { height: 300px; }
.height-large { height: 450px; }

/* Parallax */
.parallax {
  background-attachment: fixed;
}

/* Overlay Base Styles - Color is fixed black, opacity is dynamic above */
.overlay {
  position: absolute;
  inset: 0;
  background: #000000;
  z-index: 1; /* Content must be higher than this */
}

/* Container */
.container {
  width: 100%;
  max-width: 1200px;
  margin: auto;
  padding: 0 20px;
  position: relative;
  z-index: 2; /* Ensures content is above overlay */
}

/* Content */
.banner_content {
  color: #fff;
  max-width: 700px;
}

/* Alignment */
.align-left .banner_content {
  text-align: left;
  margin-left: 0;
}

.align-center .banner_content {
  text-align: center;
  margin: 0 auto;
}

.align-right .banner_content {
  text-align: right;
  margin-left: auto;
}

/* Typography */
.banner_content h2 {
  font-size: 36px;
  margin-bottom: 10px;
}

.banner_content p {
  font-size: 16px;
  margin-bottom: 20px;
}

/* Button */
.btn {
  display: inline-block;
  padding: 12px 30px;
  background: #fff;
  color: #000;
  text-decoration: none;
  border-radius: 30px;
  transition: 0.3s;
}

.btn:hover {
  background: #000;
  color: #fff;
}

/* Responsive */
@media(max-width:768px){
  .height-large { height: 300px; }

  .banner_content h2 {
    font-size: 24px;
  }

  .banner_content p {
    font-size: 14px;
  }

  .align-left,
  .align-right {
    text-align: center;
  }

  .align-left .banner_content,
  .align-right .banner_content {
    margin: 0 auto;
  }
}
</style>

{% schema %}
{
  "name": "Advanced Short Banner",
  "settings": [
    {
      "type": "header",
      "content": "Design Settings"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 40
    },
    {
      "type": "select",
      "id": "banner_height",
      "label": "Banner Height",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "parallax",
      "label": "Enable Parallax Effect",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Collection"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Discover our latest arrivals"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Advanced Short Banner",
      "category": "Banner"
    }
  ]
}
{% endschema %}