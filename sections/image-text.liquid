<div class="image_text_section">
  <div class="container">
    <div class="wrapper {% if section.settings.layout == 'right' %}reverse{% endif %}">

      <!-- Image -->
      <div class="image_box {{ section.settings.image_size }}">
        {% if section.settings.image %}
          <img 
            src="{{ section.settings.image | image_url: width: 1000 }}" 
            alt="{{ section.settings.heading | escape }}">
        {% endif %}
      </div>

      <!-- Content -->
      <div class="content_box">
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.paragraph }}</p>

        {% if section.settings.button_text != blank %}
          <a href="{{ section.settings.button_url }}" class="btn">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>

    </div>
  </div>
</div>

<style>
.image_text_section {
  padding: 80px 0;
}

/* Container */
.container {
  max-width: 1200px;
  margin: auto;
  padding: 0 20px;
}

/* Layout */
.wrapper {
  display: flex;
  align-items: center;
  gap: 40px;
}

/* Always 50% / 50% */
.image_box,
.content_box {
  width: 50%;
}

/* Reverse */
.wrapper.reverse {
  flex-direction: row-reverse;
}

/* Image Box */
.image_box {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* Image */
.image_box img {
  width: 100%;
  height: auto;
  border-radius: 12px;
  object-fit: cover;
}

/* Image Sizes (image ছোট/বড় হবে, column না) */
.image_box.small img {
  max-width: 300px;
}

.image_box.medium img {
  max-width: 450px;
}

.image_box.large img {
  max-width: 600px;
}

.image_box.full img {
  max-width: 100%;
}

/* Content */
.content_box {
  max-width: 520px;
}

.content_box h2 {
  font-size: 32px;
  margin-bottom: 15px;
}

.content_box p {
  color: #555;
  margin-bottom: 20px;
  line-height: 1.6;
}

/* Button */
.btn {
  display: inline-block;
  padding: 12px 30px;
  background: #000;
  color: #fff;
  text-decoration: none;
  border-radius: 30px;
  transition: 0.3s;
}

.btn:hover {
  opacity: 0.8;
}

/* Responsive */
@media(max-width: 768px){
  .wrapper {
    flex-direction: column;
    text-align: center;
  }

  .image_box,
  .content_box {
    width: 100%;
  }

  .content_box {
    max-width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Image Text Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image Text Section"
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph",
      "default": "This is a sample paragraph for the Image-Text section."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "Image Size",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full Width" }
      ]
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image Position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Image Left" },
        { "value": "right", "label": "Image Right" }
      ]
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL",
      "default": "/"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn More"
    }
  ],
  "presets": [
    {
      "name": "Image Text Section"
    }
  ]
}
{% endschema %}